{
  "name": "Velro Development Environment",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:22-bookworm",
  
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": true,
      "azureDnsAutoDetection": true,
      "dockerDashComposeVersion": "v2"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "bradlc.vscode-tailwindcss",
        "biomejs.biome",
        "ms-vscode.vscode-typescript-next",
        "ms-playwright.playwright",
        "supabase.supabase",
        "vercel.vscode-vercel",
        "ms-vscode.vscode-json",
        "formulahendry.auto-rename-tag",
        "christian-kohler.path-intellisense",
        "unifiedjs.vscode-mdx"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "bash": {
            "path": "/bin/bash",
            "icon": "terminal-bash"
          },
          "zsh": {
            "path": "/bin/zsh",
            "args": ["-l"],
            "icon": "terminal"
          }
        },
        "terminal.integrated.shell.linux": "/bin/zsh",
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "biomejs.biome",
        "typescript.preferences.importModuleSpecifier": "non-relative",
        "typescript.suggest.includeCompletionsForModuleExports": true,
        "typescript.preferences.includePackageJsonAutoImports": "auto",
        "editor.codeActionsOnSave": {
          "source.organizeImports": "explicit",
          "source.fixAll.biome": "explicit"
        },
        "files.associations": {
          "*.mdx": "mdx"
        }
      }
    }
  },

  "forwardPorts": [3000, 54321, 54322, 54323, 54324, 8080, 9090],
  "portsAttributes": {
    "3000": {
      "label": "Next.js App",
      "onAutoForward": "notify"
    },
    "54321": {
      "label": "Supabase API Gateway",
      "onAutoForward": "silent"
    },
    "54322": {
      "label": "Supabase PostgreSQL",
      "onAutoForward": "silent"
    },
    "54323": {
      "label": "Supabase Studio",
      "onAutoForward": "notify"
    },
    "54324": {
      "label": "Inbucket (Email Testing)",
      "onAutoForward": "notify"
    },
    "8080": {
      "label": "Development Server",
      "onAutoForward": "silent"
    },
    "9090": {
      "label": "QStash Dev Server",
      "onAutoForward": "silent"
    }
  },

  "workspaceFolder": "/workspaces/velro",
  "remoteUser": "node",
  "userEnvProbe": "loginInteractiveShell",
  "remoteEnv": {
    "SHELL": "/bin/zsh"
  },
  
  "containerEnv": {
    "SHELL": "/bin/zsh",
    "PNPM_HOME": "/pnpm",
    "PATH": "/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/pnpm",
    "NODE_OPTIONS": "--max-old-space-size=4096",
    "SUPABASE_URL": "http://localhost:54321",
    "SUPABASE_ANON_KEY": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0"
  },

  "mounts": [
    "source=${localEnv:HOME}/.gitconfig,target=/home/node/.gitconfig,type=bind,consistency=cached,readonly",
    "source=${localEnv:HOME}/.ssh,target=/home/node/.ssh,type=bind,consistency=cached,readonly",
    "source=${localEnv:HOME}/.gnupg,target=/home/node/.gnupg,type=bind,consistency=cached,readonly",
    "source=${localEnv:HOME}/.claude,target=/home/node/.claude,type=bind,consistency=cached"
  ],

  "initializeCommand": ".devcontainer/prebuild.sh",
  "postCreateCommand": "export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin && sudo mkdir -p /pnpm && sudo chown -R node:node /pnpm && sudo corepack enable && sudo corepack prepare pnpm@latest --activate && pnpm config set store-dir /pnpm/store && mkdir -p /workspaces/velro/node_modules && sudo chown -R node:node /workspaces/velro/node_modules /workspaces/velro/package.json /workspaces/velro/pnpm-lock.yaml 2>/dev/null || true && pnpm install && chmod +x .devcontainer/*.sh && sudo chsh -s /bin/zsh node && echo 'export SHELL=/bin/zsh' >> ~/.bashrc && echo 'export PATH=\"/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/pnpm\"' >> ~/.zshrc",
  "postStartCommand": "export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/pnpm && zsh .devcontainer/setup.sh && zsh .devcontainer/fix-gpg.sh",
  "postAttachCommand": "export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/pnpm && zsh .devcontainer/start-services.sh || echo '⚠️  Services startup had issues, but container is ready'"
}