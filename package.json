{
  "name": "velro",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm supabase:types && next dev --turbopack",
    "build": "pnpm supabase:types:ci && next build --turbopack",
    "start": "next start",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "supabase:start": "pnpx supabase start",
    "supabase:stop": "pnpx supabase stop",
    "supabase:types": "pnpm supabase gen types typescript --local > src/lib/gen.types.ts",
    "supabase:types:ci": "test -n \"$POSTGRES_URL\" && pnpm supabase gen types typescript --db-url \"$POSTGRES_URL\" > src/lib/gen.types.ts",
    "qstash:dev": "pnpx @upstash/qstash-cli dev",
    "setup:env": "./scripts/setup-env.sh",
    "workflow:assign": "./workflow/scripts/workflow-manager.sh assign",
    "workflow:orchestrator": "./workflow/scripts/orchestrator.sh"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.56.0",
    "@upstash/qstash": "^2.8.2",
    "next": "15.5.2",
    "react": "^19",
    "react-dom": "^19",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "happy-dom": "^18.0.1",
    "lefthook": "^1.12.3",
    "supabase": "^2.39.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
