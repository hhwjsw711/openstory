{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:https": "vite dev --experimental-https --experimental-https-key certs/localhost-key.pem --experimental-https-cert certs/localhost.pem",
    "build": "vite build",
    "start": "vite start",
    "preview": "vite preview",
    "build:bun": "bun run --bun vite build",
    "start:bun": "bun --bun .output/server/index.mjs",
    "lint": "bunx oxlint --type-aware",
    "lint:fix": "bunx oxlint --type-aware --fix",
    "dead-code": "bun --bun knip",
    "dead-code:fix": "bun --bun knip --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint:open": "./scripts/lint-and-open.sh",
    "typecheck": "tsgo --noEmit",
    "test": "bun test",
    "test:ui": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "test:watch": "bun test --watch",
    "db:generate": "bun --bun drizzle-kit generate",
    "db:migrate": "bun --bun drizzle-kit migrate",
    "db:push": "bun --bun drizzle-kit push",
    "db:studio": "bun --env-file=.env.local --env-file=.env.development.local drizzle-kit studio",
    "db:check": "bun --bun drizzle-kit check",
    "db:seed": "bun --bun scripts/seed.ts",
    "db:seed:local": "bun --bun scripts/seed.ts --local",
    "db:migrate-templates": "bun --bun scripts/migrate-system-templates.ts",
    "db:setup": "bun db:migrate && bun db:seed",
    "db:generate:local": "bun --bun drizzle-kit generate --config=drizzle.config.local.ts",
    "db:migrate:local": "bun --bun drizzle-kit migrate --config=drizzle.config.local.ts",
    "db:push:local": "bun --bun drizzle-kit push --config=drizzle.config.local.ts",
    "db:studio:local": "bun drizzle-kit studio --config=drizzle.config.local.ts",
    "db:setup:local": "bun db:migrate:local && bun db:seed:local",
    "qstash:dev": "docker run -p 8080:8080 public.ecr.aws/upstash/qstash:latest qstash dev",
    "setup:env": "./scripts/setup-env.sh",
    "bash:setup:env": "bash ./scripts/setup-env.sh",
    "cert:setup": "bash ./scripts/setup-cert.sh",
    "cert:trust": "mkcert -install",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "system-prompt": "bun ./scripts/system-prompt.ts | pbcopy",
    "letzai:codegen": "bunx @hey-api/openapi-ts -f src/lib/letzai/letzai-config.ts",
    "secrets:dev": "doppler secrets download --config=dev --format=env --no-file > .env.local",
    "secrets:stg": "doppler secrets download --config=stg --format=env --no-file > .env.local",
    "secrets:prd": "doppler secrets download --config=prd --format=env --no-file > .env.production",
    "cf:typegen:stg": "wrangler types --env=stg",
    "cf:typegen:prd": "wrangler types --env=prd",
    "cf:secrets:stg": "doppler secrets --json --config=stg | jq -c 'with_entries(.value = .value.computed) | del(.R2_PUBLIC_ASSETS_BUCKET, .NEXT_INC_CACHE_R2_BUCKET)' | wrangler secret bulk --env=stg",
    "cf:secrets:prd": "doppler secrets --json --config=prd | jq -c 'with_entries(.value = .value.computed) | del(.R2_PUBLIC_ASSETS_BUCKET, .NEXT_INC_CACHE_R2_BUCKET)' | wrangler secret bulk --env=prd",
    "cf:build:prd": "bun --bun run cf:typegen:prd && BUILD_CLOUDFLARE=1 bun --bun run build",
    "cf:build:stg": "bun --bun run cf:typegen:stg && BUILD_CLOUDFLARE=1 bun --bun run build",
    "cf:preview": "BUILD_CLOUDFLARE=1 vite preview",
    "cf:deploy:prd": "bun --bun run cf:build:prd && wrangler deploy --env=prd --name=frontend-prd",
    "cf:deploy:stg": "bun --bun run cf:build:stg && wrangler deploy --env=stg --name=frontend-stg",
    "knip": "knip"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.948.0",
    "@aws-sdk/s3-request-presigner": "^3.948.0",
    "@cf-wasm/photon": "^0.3.4",
    "@fal-ai/client": "^1.7.2",
    "@libsql/client": "^0.15.15",
    "@modelcontextprotocol/sdk": "^1.24.3",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@react-email/render": "^2.0.0",
    "@tanstack/react-query": "^5.90.12",
    "@tanstack/react-query-devtools": "^5.91.1",
    "@tanstack/react-router": "^1.141.1",
    "@tanstack/react-start": "^1.141.1",
    "@tanstack/react-virtual": "^3.13.13",
    "@tanstack/zod-adapter": "^1.141.2",
    "@unpic/react": "^1.0.2",
    "@upstash/qstash": "^2.8.4",
    "@upstash/realtime": "^1.0.0",
    "@upstash/redis": "^1.35.7",
    "@upstash/workflow": "^0.2.23",
    "@vidstack/react": "^1.12.13",
    "better-auth": "^1.4.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.8",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "lucide-react": "^0.560.0",
    "mcp-handler": "^1.0.4",
    "nitro": "^3.0.1-alpha.1",
    "postcss": "^8.5.6",
    "react": "^19.2.2",
    "react-dom": "^19.2.2",
    "resend": "^6.6.0",
    "tailwind-merge": "^3.4.0",
    "ulid": "^3.0.2",
    "zod": "^4.1.13"
  },
  "imports": {
    "#env": {
      "workerd": "./src/lib/env/cloudflare.ts",
      "default": "./src/lib/env/default.ts"
    },
    "#redis": {
      "workerd": "./src/lib/db/redis-cloudflare.ts",
      "default": "./src/lib/db/redis.ts"
    },
    "#db-client": {
      "development": "./src/lib/db/client-local.ts",
      "default": "./src/lib/db/client-web.ts"
    },
    "#actions/*": {
      "storybook": "./src/app/actions/*/index.mock.ts",
      "default": "./src/app/actions/*/index.ts"
    }
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.3",
    "@cloudflare/vite-plugin": "^1.17.1",
    "@faker-js/faker": "^10.1.0",
    "@storybook/addon-a11y": "^10.1.8",
    "@storybook/addon-docs": "^10.1.8",
    "@storybook/addon-onboarding": "^10.1.8",
    "@storybook/addon-themes": "^10.1.8",
    "@storybook/react-vite": "^10.1.8",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "1.3.4",
    "@types/node": "^24.10.4",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20251211.1",
    "@vitejs/plugin-react": "^5.1.2",
    "knip": "^5.73.4",
    "lefthook": "^2.0.9",
    "msw": "^2.12.4",
    "msw-storybook-addon": "^2.0.6",
    "oxfmt": "^0.17.0",
    "oxlint": "^1.32.0",
    "oxlint-tsgolint": "^0.8.5",
    "playwright": "^1.57.0",
    "shadcn": "^3.5.2",
    "storybook": "^10.1.8",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vite-tsconfig-paths": "^5.1.4",
    "wrangler": "^4.54.0"
  },
  "engines": {
    "node": ">=24 < 25",
    "bun": ">=1.3.0 < 2"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
