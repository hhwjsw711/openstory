{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --bun next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "bunx oxlint --type-aware",
    "lint:fix": "bunx oxlint --type-aware --fix",
    "format": "bunx prettier --write .",
    "format:check": "bunx prettier --check .",
    "lint:open": "./scripts/lint-and-open.sh",
    "test": "bun test",
    "test:ui": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "test:watch": "bun test --watch",
    "db:generate": "bun --bun drizzle-kit generate",
    "db:migrate": "bun --bun drizzle-kit migrate",
    "db:push": "bun --bun drizzle-kit push",
    "db:studio": "bun --env-file=.env.local --env-file=.env.development.local drizzle-kit studio",
    "db:check": "bun --bun drizzle-kit check",
    "db:seed": "bun --bun scripts/seed.ts",
    "db:setup": "bun db:migrate && bun db:seed",
    "qstash:dev": "docker run -p 8080:8080 public.ecr.aws/upstash/qstash:latest qstash dev",
    "setup:env": "./scripts/setup-env.sh",
    "bash:setup:env": "bash ./scripts/setup-env.sh",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "system-prompt": "bun ./scripts/system-prompt.ts | pbcopy",
    "deploy:production": "opennextjs-cloudflare build --env=\"\" && opennextjs-cloudflare deploy --env=\"\"",
    "deploy:preview": "build:cloudflare:preview && opennextjs-cloudflare deploy --env=preview",
    "letzai:codegen": "bunx @hey-api/openapi-ts -f src/lib/letzai/letzai-config.ts",
    "secrets:dev": "doppler secrets download --config=dev --format=env > .dev.vars && cp .dev.vars .env.local",
    "cf:typegen": "doppler run --mount .env -- bun wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "cf:secrets:stg": "doppler secrets --json --config=stg | jq -c 'with_entries(.value = .value.computed)' | wrangler secret bulk --env stg",
    "cf:secrets:prd": "doppler secrets --json --config=prd | jq -c 'with_entries(.value = .value.computed)' | wrangler secret bulk --env \"\"",
    "cf:build:prd": "BUILD_CLOUDFLARE=1 opennextjs-cloudflare build --env=\"\"",
    "cf:build:stg": "BUILD_CLOUDFLARE=1 opennextjs-cloudflare build --env=stg",
    "cf:preview": "bun run cf:build:stg && opennextjs-cloudflare preview",
    "cf:deploy:prd": "bun run cf:build:prd && BUILD_CLOUDFLARE=1 opennextjs-cloudflare deploy --env=\"\"",
    "cf:deploy:stg": "bun run cf:build:stg && BUILD_CLOUDFLARE=1 opennextjs-cloudflare deploy --env=stg",
    "cf:upload:prd": "BUILD_CLOUDFLARE=1 opennextjs-cloudflare upload --env=\"\"",
    "cf:upload:stg": "BUILD_CLOUDFLARE=1 opennextjs-cloudflare upload --env=stg"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.933.0",
    "@aws-sdk/s3-request-presigner": "^3.933.0",
    "@better-fetch/fetch": "^1.1.18",
    "@cerebras/cerebras_cloud_sdk": "^1.59.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fal-ai/client": "^1.7.2",
    "@libsql/client": "^0.15.15",
    "@opennextjs/cloudflare": "^1.13.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@react-email/components": "^1.0.1",
    "@react-email/render": "^2.0.0",
    "@tanstack/react-query": "^5.90.10",
    "@tanstack/react-query-devtools": "^5.90.2",
    "@upstash/qstash": "^2.8.4",
    "@upstash/workflow": "^0.2.22",
    "@vidstack/react": "^1.12.13",
    "better-auth": "^1.3.34",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.7",
    "drizzle-orm": "^0.44.7",
    "drizzle-zod": "^0.8.3",
    "lucide-react": "^0.554.0",
    "next": "15.5.2",
    "openai": "^6.9.1",
    "postcss": "^8.5.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "resend": "^6.4.2",
    "tailwind-merge": "^3.4.0",
    "ulid": "^3.0.1",
    "zod": "^4.1.12"
  },
  "imports": {
    "#env": {
      "default": "./src/lib/env/default.ts"
    },
    "#db-client": {
      "development": "./src/lib/db/client-local.ts",
      "default": "./src/lib/db/client-web.ts"
    },
    "#actions/*": {
      "storybook": "./src/app/actions/*/index.mock.ts",
      "default": "./src/app/actions/*/index.ts"
    }
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.3",
    "@faker-js/faker": "^10.1.0",
    "@storybook/addon-a11y": "^10.0.8",
    "@storybook/addon-docs": "^10.0.8",
    "@storybook/addon-onboarding": "^10.0.8",
    "@storybook/addon-themes": "^10.0.8",
    "@storybook/addon-vitest": "^10.0.8",
    "@storybook/nextjs": "^10.0.8",
    "@storybook/nextjs-vite": "^10.0.8",
    "@tailwindcss/postcss": "^4.1.17",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "latest",
    "@types/node": "22",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "lefthook": "^2.0.4",
    "msw": "^2.12.2",
    "msw-storybook-addon": "^2.0.6",
    "oxlint": "^1.29.0",
    "oxlint-tsgolint": "^0.7.1",
    "playwright": "^1.56.1",
    "prettier": "^3.6.2",
    "shadcn": "^3.5.0",
    "storybook": "^10.0.8",
    "tailwindcss": "^4.1.17",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.49.0"
  },
  "engines": {
    "node": ">=22 < 24",
    "bun": ">=1.3.0 < 2"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
