{
  "name": "velro",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm supabase:types && next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "supabase:start": "pnpx supabase start",
    "supabase:stop": "pnpx supabase stop",
    "supabase:types": "pnpm supabase gen types typescript --local > src/lib/supabase/gen.types.ts && biome check --write src/lib/supabase/gen.types.ts",
    "supabase:types:ci": "test -n \"$POSTGRES_URL\" && pnpm supabase gen types typescript --db-url \"$POSTGRES_URL\" > src/lib/supabase/gen.types.ts && biome check --write src/lib/supabase/gen.types.ts",
    "qstash:dev": "pnpx @upstash/qstash-cli dev",
    "setup:env": "./scripts/setup-env.sh",
    "workflow:assign": "./workflow/scripts/workflow-manager.sh assign",
    "workflow:orchestrator": "./workflow/scripts/orchestrator.sh",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.56.0",
    "@tanstack/react-query": "^5.85.6",
    "@tanstack/react-query-devtools": "^5.85.6",
    "@upstash/qstash": "^2.8.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.542.0",
    "next": "15.5.2",
    "postcss": "^8.5.6",
    "react": "^19",
    "react-dom": "^19",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.5"
  },
  "exports": {
    "./actions/*": {
      "storybook": "./src/app/actions/*/index.mock.ts",
      "default": "./src/app/actions/*/index.ts"
    },
    "./actions": {
      "storybook": "./src/app/actions/index.mock.ts",
      "default": "./src/app/actions/index.ts"
    }
  },
  "imports": {
    "#actions/*": {
      "storybook": "./src/app/actions/*/index.mock.ts",
      "default": "./src/app/actions/*/index.ts"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.2",
    "@chromatic-com/storybook": "^4.1.1",
    "@faker-js/faker": "^10.0.0",
    "@storybook/addon-a11y": "^9.1.3",
    "@storybook/addon-docs": "^9.1.3",
    "@storybook/addon-onboarding": "^9.1.3",
    "@storybook/addon-vitest": "^9.1.3",
    "@storybook/nextjs": "^9.1.3",
    "@storybook/nextjs-vite": "^9.1.3",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/browser": "3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "happy-dom": "^18.0.1",
    "lefthook": "^1.12.3",
    "playwright": "^1.55.0",
    "shadcn": "^3.0.0",
    "storybook": "^9.1.3",
    "supabase": "^2.39.2",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.3.7",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
