{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun run --bun next dev --turbopack",
    "build": "bun run --bun next build --turbopack",
    "start": "bun run --bun next start",
    "lint": "bunx oxlint --type-aware",
    "lint:fix": "bunx oxlint --type-aware --fix",
    "format": "bunx prettier --write .",
    "format:check": "bunx prettier --check .",
    "lint:open": "./scripts/lint-and-open.sh",
    "test": "bun test",
    "test:ui": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "test:watch": "bun test --watch",
    "db:generate": "bun --bun drizzle-kit generate",
    "db:migrate": "bun --bun drizzle-kit migrate",
    "db:push": "bun --bun drizzle-kit push",
    "db:studio": "bun --env-file=.env.local --env-file=.env.development.local drizzle-kit studio",
    "db:check": "bun --bun drizzle-kit check",
    "db:seed": "bun --bun scripts/seed.ts",
    "db:setup": "bun db:migrate && bun db:seed",
    "qstash:dev": "docker run -p 8080:8080 public.ecr.aws/upstash/qstash:latest qstash dev",
    "setup:env": "./scripts/setup-env.sh",
    "bash:setup:env": "bash ./scripts/setup-env.sh",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "system-prompt": "bun ./scripts/system-prompt.ts | pbcopy"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.930.0",
    "@aws-sdk/s3-request-presigner": "^3.930.0",
    "@better-auth/client": "^0.0.2-alpha.3",
    "@better-fetch/fetch": "^1.1.18",
    "@cerebras/cerebras_cloud_sdk": "^1.56.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fal-ai/client": "^1.6.2",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@react-email/components": "^0.5.6",
    "@react-email/render": "^1.3.2",
    "@tanstack/react-query": "^5.85.6",
    "@tanstack/react-query-devtools": "^5.85.6",
    "@upstash/qstash": "^2.8.4",
    "@upstash/workflow": "^0.2.22",
    "@vidstack/react": "^1.12.13",
    "better-auth": "^1.3.24",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.5",
    "drizzle-orm": "^0.44.6",
    "drizzle-zod": "^0.8.3",
    "lucide-react": "^0.542.0",
    "next": "15.5.2",
    "openai": "^5.19.1",
    "postcss": "^8.5.6",
    "@libsql/client": "^0.14.0",
    "ulid": "^2.3.0",
    "react": "^19",
    "react-dom": "^19",
    "resend": "^6.1.2",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.5"
  },
  "imports": {
    "#actions/*": {
      "storybook": "./src/app/actions/*/index.mock.ts",
      "default": "./src/app/actions/*/index.ts"
    }
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.1",
    "@faker-js/faker": "^10.0.0",
    "@storybook/addon-a11y": "^9.1.3",
    "@storybook/addon-docs": "^9.1.3",
    "@storybook/addon-onboarding": "^9.1.3",
    "@storybook/addon-themes": "^10.0.1",
    "@storybook/addon-vitest": "^9.1.3",
    "@storybook/nextjs": "^9.1.3",
    "@storybook/nextjs-vite": "^9.1.3",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "latest",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "lefthook": "^1.12.3",
    "msw": "^2.11.6",
    "msw-storybook-addon": "^2.0.6",
    "oxlint": "^1.28.0",
    "oxlint-tsgolint": "^0.5.1",
    "playwright": "^1.55.0",
    "prettier": "^3.6.2",
    "shadcn": "^3.0.0",
    "storybook": "^9.1.3",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.3.7",
    "typescript": "^5",
    "wrangler": "^4.47.0"
  },
  "engines": {
    "node": ">=22",
    "bun": ">=1.3.0"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
