# Auth
BETTER_AUTH_SECRET=your-secret-here
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Database (Turso)
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-turso-token

# QStash (Workflows)
QSTASH_TOKEN=your-qstash-token
QSTASH_URL=http://127.0.0.1:8080
QSTASH_CURRENT_SIGNING_KEY=your-signing-key
QSTASH_NEXT_SIGNING_KEY=your-next-signing-key

# Redis (Upstash)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# Storage (Cloudflare R2)
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=your-bucket-name
R2_PUBLIC_STORAGE_DOMAIN=storage.example.com
R2_PUBLIC_ASSETS_BUCKET=your-assets-bucket
R2_PUBLIC_ASSETS_DOMAIN=assets.example.com

# AI Services
FAL_KEY=your-fal-key
FAL_CONCURRENCY_LIMIT=10
OPENROUTER_KEY=your-openrouter-key
CEREBRAS_API_KEY=your-cerebras-key
LETZAI_API_KEY=your-letzai-key

# Billing (Stripe)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Email (Resend)
RESEND_API_KEY=your-resend-key
EMAIL_FROM=noreply@example.com

# Langfuse Observability
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_SECRET_KEY=""
LANGFUSE_BASE_URL="https://cloud.langfuse.com"

# Optional: Doppler (secrets management)
DOPPLER_PROJECT=frontend
DOPPLER_CONFIG=dev
DOPPLER_ENVIRONMENT=dev
