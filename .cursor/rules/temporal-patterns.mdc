# Temporal Workflow Patterns

## Workflow Definition

```typescript
import { proxyActivities } from '@temporalio/workflow';
import type * as activities from '../activities';

const { generateImage, saveToStorage, updateFrameStatus } = proxyActivities<typeof activities>({
  startToCloseTimeout: '10 minutes',
  retry: {
    maximumAttempts: 3,
    backoffCoefficient: 2,
    initialInterval: '1s',
    maximumInterval: '60s',
  },
});

export async function frameGenerationWorkflow(params: {
  frameId: string;
  userId: string;
  modelParams: {
    model: string;
    prompt: string;
    styleStack?: object;
  };
}): Promise<{ success: boolean; imageUrl?: string; error?: string }> {
  try {
    // Update status to processing
    await updateFrameStatus({ frameId: params.frameId, status: 'processing' });
    
    // Generate image via Fal.ai
    const result = await generateImage({
      model: params.modelParams.model,
      prompt: params.modelParams.prompt,
      styleStack: params.modelParams.styleStack,
    });
    
    // Save to storage
    const imageUrl = await saveToStorage({
      frameId: params.frameId,
      imageData: result.imageData,
      userId: params.userId,
    });
    
    // Update status to completed
    await updateFrameStatus({
      frameId: params.frameId,
      status: 'completed',
      imageUrl,
    });
    
    return { success: true, imageUrl };
  } catch (error) {
    await updateFrameStatus({
      frameId: params.frameId,
      status: 'failed',
      error: error instanceof Error ? error.message : 'Unknown error',
    });
    
    return {
      success: false,
      error: error instanceof Error ? error.message : 'Unknown error',
    };
  }
}
```

## Activity Implementation

```typescript
// apps/backend/src/workflows/activities/frame-generation.ts
import { db } from '../../db';
import { frames } from '../../db/schema';
import { eq } from 'drizzle-orm';
import { fal } from '../../lib/ai/fal-client';
import { s3Client } from '../../lib/storage/s3';

export async function generateImage(params: {
  model: string;
  prompt: string;
  styleStack?: object;
}): Promise<{ imageData: Buffer }> {
  const result = await fal.subscribe(params.model, {
    input: {
      prompt: params.prompt,
      ...params.styleStack,
    },
  });
  
  // Download image
  const response = await fetch(result.images[0].url);
  const imageData = Buffer.from(await response.arrayBuffer());
  
  return { imageData };
}

export async function saveToStorage(params: {
  frameId: string;
  imageData: Buffer;
  userId: string;
}): Promise<string> {
  // Upload to S3-compatible storage
  const key = `frames/${params.userId}/${params.frameId}.png`;
  await s3Client.putObject({
    Bucket: process.env.STORAGE_BUCKET,
    Key: key,
    Body: params.imageData,
    ContentType: 'image/png',
  });
  
  const cdnUrl = process.env.CDN_URL || process.env.STORAGE_URL;
  return `${cdnUrl}/${key}`;
}

export async function updateFrameStatus(params: {
  frameId: string;
  status: string;
  imageUrl?: string;
  error?: string;
}): Promise<void> {
  await db
    .update(frames)
    .set({
      status: params.status,
      thumbnailUrl: params.imageUrl,
      error: params.error,
      updatedAt: new Date(),
    })
    .where(eq(frames.id, params.frameId));
}
```

## Temporal Client Setup

```typescript
// apps/backend/src/workflows/client.ts
import { Connection, Client } from '@temporalio/client';

let temporalClient: Client | null = null;

export async function getTemporalClient(): Promise<Client> {
  if (temporalClient) {
    return temporalClient;
  }
  
  const connection = await Connection.connect({
    address: process.env.TEMPORAL_ADDRESS || 'localhost:7233',
  });
  
  temporalClient = new Client({
    connection,
    namespace: process.env.TEMPORAL_NAMESPACE || 'default',
  });
  
  return temporalClient;
}

export { temporalClient };
```

## Worker Setup

```typescript
// apps/backend/src/workflows/worker.ts
import { Worker } from '@temporalio/worker';
import * as activities from './activities';

async function run() {
  const worker = await Worker.create({
    workflowsPath: require.resolve('./index'),
    activities,
    taskQueue: 'frame-generation',
    // Optional: configure worker
    maxConcurrentActivityTaskExecutions: 10,
    maxConcurrentWorkflowTaskExecutions: 100,
  });
  
  await worker.run();
}

run().catch((err) => {
  console.error('Worker error:', err);
  process.exit(1);
});
```

## Starting a Workflow from Elysia Route

```typescript
import { Elysia, t } from 'elysia';
import { getTemporalClient } from '../workflows/client';
import { frameGenerationWorkflow } from '../workflows/frame-generation';

export const jobsRoute = new Elysia({ prefix: '/api/jobs' })
  .post('/generate-frame', async ({ body, error }) => {
    try {
      const client = await getTemporalClient();
      
      const handle = await client.workflow.start(frameGenerationWorkflow, {
        taskQueue: 'frame-generation',
        workflowId: `frame-${body.frameId}-${Date.now()}`,
        args: [{
          frameId: body.frameId,
          userId: body.userId,
          modelParams: body.modelParams,
        }],
      });
      
      return {
        success: true,
        data: {
          workflowId: handle.workflowId,
          runId: handle.firstExecutionRunId,
        },
      };
    } catch (err) {
      console.error('Failed to start workflow:', err);
      return error(500, 'Failed to start generation workflow');
    }
  }, {
    body: t.Object({
      frameId: t.String(),
      userId: t.String(),
      modelParams: t.Object({
        model: t.String(),
        prompt: t.String(),
        styleStack: t.Optional(t.Object({})),
      }),
    }),
  });
```

## Querying Workflow Status

```typescript
import { Elysia, t } from 'elysia';
import { getTemporalClient } from '../workflows/client';

export const jobStatusRoute = new Elysia({ prefix: '/api/jobs' })
  .get('/status/:workflowId', async ({ params, error }) => {
    try {
      const client = await getTemporalClient();
      const handle = client.workflow.getHandle(params.workflowId);
      
      const description = await handle.describe();
      
      return {
        success: true,
        data: {
          workflowId: description.workflowId,
          runId: description.runId,
          status: description.status.name,
          startTime: description.startTime,
          closeTime: description.closeTime,
        },
      };
    } catch (err) {
      console.error('Failed to get workflow status:', err);
      return error(404, 'Workflow not found');
    }
  }, {
    params: t.Object({
      workflowId: t.String(),
    }),
  });
```

## Workflow with Child Workflows

```typescript
import { proxyActivities, startChild } from '@temporalio/workflow';
import type * as activities from '../activities';

const { analyzeScript } = proxyActivities<typeof activities>({
  startToCloseTimeout: '5 minutes',
});

export async function sequenceGenerationWorkflow(params: {
  sequenceId: string;
  script: string;
  userId: string;
}): Promise<{ success: boolean; framesGenerated: number }> {
  // Analyze script to get frame descriptions
  const analysis = await analyzeScript({ script: params.script });
  
  // Start child workflows for each frame
  const frameWorkflows = analysis.frames.map((frame, index) =>
    startChild(frameGenerationWorkflow, {
      workflowId: `frame-${params.sequenceId}-${index}`,
      taskQueue: 'frame-generation',
      args: [{
        frameId: frame.id,
        userId: params.userId,
        modelParams: {
          model: 'flux-pro',
          prompt: frame.description,
        },
      }],
    })
  );
  
  // Wait for all child workflows to complete
  const results = await Promise.all(frameWorkflows);
  
  const successCount = results.filter(r => r.success).length;
  
  return {
    success: successCount === results.length,
    framesGenerated: successCount,
  };
}
```

## Signals and Queries

```typescript
import { defineSignal, defineQuery, setHandler, proxyActivities } from '@temporalio/workflow';
import type * as activities from '../activities';

// Define signal and query
const pauseSignal = defineSignal('pause');
const resumeSignal = defineSignal('resume');
const getProgressQuery = defineQuery<number>('getProgress');

export async function longRunningWorkflow(params: { totalSteps: number }) {
  let isPaused = false;
  let currentStep = 0;
  
  // Set signal handlers
  setHandler(pauseSignal, () => { isPaused = true; });
  setHandler(resumeSignal, () => { isPaused = false; });
  setHandler(getProgressQuery, () => (currentStep / params.totalSteps) * 100);
  
  for (let i = 0; i < params.totalSteps; i++) {
    // Wait if paused
    while (isPaused) {
      await new Promise(resolve => setTimeout(resolve, 100));
    }
    
    // Process step
    currentStep = i + 1;
    // ... do work
  }
  
  return { success: true, stepsCompleted: currentStep };
}

// Sending signals from client
const client = await getTemporalClient();
const handle = client.workflow.getHandle(workflowId);
await handle.signal(pauseSignal);

// Querying workflow
const progress = await handle.query(getProgressQuery);
```

## Scheduled Workflows (Cron)

```typescript
import { Elysia } from 'elysia';
import { getTemporalClient } from '../workflows/client';
import { cleanupWorkflow } from '../workflows/cleanup';

export const scheduleRoute = new Elysia({ prefix: '/api/schedules' })
  .post('/cleanup', async ({ error }) => {
    try {
      const client = await getTemporalClient();
      
      await client.workflow.start(cleanupWorkflow, {
        taskQueue: 'maintenance',
        workflowId: 'cleanup-workflow',
        cronSchedule: '0 2 * * *', // Run at 2 AM every day
        args: [],
      });
      
      return { success: true, message: 'Cleanup workflow scheduled' };
    } catch (err) {
      console.error('Failed to schedule cleanup:', err);
      return error(500, 'Failed to schedule workflow');
    }
  });
```

## Error Handling and Retries

```typescript
import { proxyActivities, ActivityFailure } from '@temporalio/workflow';
import type * as activities from '../activities';

const { riskyOperation } = proxyActivities<typeof activities>({
  startToCloseTimeout: '5 minutes',
  retry: {
    maximumAttempts: 5,
    backoffCoefficient: 2,
    initialInterval: '1s',
    maximumInterval: '60s',
    nonRetryableErrorTypes: ['ValidationError'], // Don't retry these
  },
});

export async function resilientWorkflow() {
  try {
    const result = await riskyOperation();
    return { success: true, result };
  } catch (error) {
    if (error instanceof ActivityFailure) {
      console.error('Activity failed after retries:', error.cause);
      return { success: false, error: error.message };
    }
    throw error;
  }
}
```

## Testing Workflows

```typescript
import { TestWorkflowEnvironment } from '@temporalio/testing';
import { Worker } from '@temporalio/worker';
import { frameGenerationWorkflow } from './frame-generation';
import * as activities from './activities';
import { test, expect, beforeAll, afterAll } from 'bun:test';

let testEnv: TestWorkflowEnvironment;

beforeAll(async () => {
  testEnv = await TestWorkflowEnvironment.createLocal();
});

afterAll(async () => {
  await testEnv?.teardown();
});

test('frame generation workflow succeeds', async () => {
  const { client, nativeConnection } = testEnv;
  
  const worker = await Worker.create({
    connection: nativeConnection,
    taskQueue: 'test',
    workflowsPath: require.resolve('./frame-generation'),
    activities,
  });
  
  await worker.runUntil(async () => {
    const handle = await client.workflow.start(frameGenerationWorkflow, {
      taskQueue: 'test',
      workflowId: 'test-frame-generation',
      args: [{
        frameId: 'test-frame-id',
        userId: 'test-user-id',
        modelParams: {
          model: 'flux-pro',
          prompt: 'A beautiful sunset',
        },
      }],
    });
    
    const result = await handle.result();
    expect(result.success).toBe(true);
    expect(result.imageUrl).toBeDefined();
  });
});
```
