# Elysia Backend Patterns

## ArkType Validation Integration

ArkType is used for runtime type validation in Elysia routes, providing excellent TypeScript inference and performance.

```typescript
import { type } from 'arktype';

// Define ArkType schemas
const sequenceIdSchema = type('string.uuid');
const createSequenceSchema = type({
  name: 'string',
  'description?': 'string',
  'requiresAuth?': 'boolean',
});

// Type inference from ArkType
type CreateSequenceInput = typeof createSequenceSchema.infer;
```

## Standard Route Handler with Authentication

```typescript
import { Elysia } from 'elysia';
import { type } from 'arktype';
import { authPlugin } from './plugins/auth';
import { db } from './db';
import { sequences } from './db/schema';
import { eq } from 'drizzle-orm';

// ArkType schemas
const sequenceIdSchema = type('string.uuid');
const createSequenceSchema = type({
  name: 'string',
  'description?': 'string',
  'requiresAuth?': 'boolean',
});

export const sequencesRoute = new Elysia({ prefix: '/api/sequences' })
  .use(authPlugin) // Adds `user` to context if authenticated
  .get('/:id', async ({ params, user, error }) => {
    // Validate UUID with ArkType
    const idValidation = sequenceIdSchema(params.id);
    if (idValidation instanceof type.errors) {
      return error(400, `Invalid sequence ID: ${idValidation.summary}`);
    }
    
    // Check authentication
    if (!user) {
      return error(401, 'Authentication required');
    }
    
    // Query with Drizzle
    const sequence = await db.query.sequences.findFirst({
      where: eq(sequences.id, params.id),
      with: {
        frames: true,
        style: true,
      },
    });
    
    if (!sequence) {
      return error(404, 'Sequence not found');
    }
    
    // Check authorization (team-based)
    if (sequence.teamId !== user.teamId) {
      return error(403, 'Access denied');
    }
    
    return { success: true, data: sequence };
  })
  .post('/', async ({ body, user, error }) => {
    if (!user) {
      return error(401, 'Authentication required');
    }
    
    // Validate body with ArkType
    const bodyValidation = createSequenceSchema(body);
    if (bodyValidation instanceof type.errors) {
      return error(400, `Validation error: ${bodyValidation.summary}`);
    }
    
    const validatedData = bodyValidation.data;
    
    // Block anonymous users for certain operations
    if (user.isAnonymous && validatedData.requiresAuth) {
      return error(403, 'Account required for this operation');
    }
    
    // Insert with Drizzle
    const [newSequence] = await db.insert(sequences).values({
      ...validatedData,
      teamId: user.teamId,
      createdBy: user.id,
    }).returning();
    
    return { success: true, data: newSequence };
  });
```

## BetterAuth Integration

```typescript
import { Elysia } from 'elysia';
import { betterAuth } from 'better-auth';
import { db } from './db';

export const auth = betterAuth({
  database: db,
  emailAndPassword: {
    enabled: true,
  },
  anonymous: {
    enabled: true,
  },
});

// Auth plugin for Elysia
export const authPlugin = new Elysia({ name: 'auth' })
  .derive(async ({ headers, cookie }) => {
    const sessionToken = cookie['better-auth.session_token']?.value;
    
    if (!sessionToken) {
      return { user: null, session: null };
    }
    
    const session = await auth.api.getSession({
      headers: new Headers({ cookie: `better-auth.session_token=${sessionToken}` }),
    });
    
    return {
      user: session?.user ?? null,
      session: session ?? null,
    };
  });
```

## ArkType Validation Plugin

Create a reusable validation plugin for ArkType:

```typescript
import { Elysia } from 'elysia';
import { type, Type } from 'arktype';

export const arktype = <T extends Type>(schema: T) => {
  return new Elysia()
    .derive({ as: 'scoped' }, ({ body }) => {
      const validation = schema(body);
      
      if (validation instanceof type.errors) {
        throw new Error(`Validation failed: ${validation.summary}`);
      }
      
      return {
        validatedBody: validation.data as T['infer'],
      };
    });
};

// Usage
import { arktype } from './plugins/arktype';

const createFrameSchema = type({
  frameId: 'string.uuid',
  prompt: 'string',
  model: 'string',
});

export const framesRoute = new Elysia()
  .post('/frames', async ({ validatedBody }) => {
    // validatedBody is fully typed!
    console.log(validatedBody.frameId);
    return { success: true };
  }, {
    beforeHandle: arktype(createFrameSchema),
  });
```

## Temporal Workflow Integration

```typescript
import { Elysia } from 'elysia';
import { type } from 'arktype';
import { authPlugin } from './plugins/auth';
import { temporalClient } from './workflows/client';
import { frameGenerationWorkflow } from './workflows/frame-generation';

// ArkType schema for frame generation
const generateFrameSchema = type({
  frameId: 'string.uuid',
  modelParams: {
    model: 'string',
    prompt: 'string',
  },
});

export const jobsRoute = new Elysia({ prefix: '/api/jobs' })
  .use(authPlugin)
  .post('/generate-frame', async ({ body, user, error }) => {
    if (!user) {
      return error(401, 'Authentication required');
    }
    
    // Validate with ArkType
    const validation = generateFrameSchema(body);
    if (validation instanceof type.errors) {
      return error(400, `Validation error: ${validation.summary}`);
    }
    
    const validatedData = validation.data;
    
    // Start Temporal workflow
    const handle = await temporalClient.workflow.start(frameGenerationWorkflow, {
      taskQueue: 'frame-generation',
      workflowId: `frame-${validatedData.frameId}-${Date.now()}`,
      args: [{
        frameId: validatedData.frameId,
        userId: user.id,
        modelParams: validatedData.modelParams,
      }],
    });
    
    return {
      success: true,
      data: {
        workflowId: handle.workflowId,
        runId: handle.firstExecutionRunId,
      },
    };
  });
```

## Error Handling Plugin

```typescript
import { Elysia } from 'elysia';

export const errorPlugin = new Elysia({ name: 'error' })
  .onError(({ code, error, set }) => {
    console.error('[API Error]', code, error);
    
    switch (code) {
      case 'VALIDATION':
        set.status = 400;
        return {
          success: false,
          error: 'Validation failed',
          details: error.message,
        };
        
      case 'NOT_FOUND':
        set.status = 404;
        return {
          success: false,
          error: 'Resource not found',
        };
        
      case 'PARSE':
        set.status = 400;
        return {
          success: false,
          error: 'Invalid request body',
        };
        
      default:
        set.status = 500;
        return {
          success: false,
          error: 'Internal server error',
        };
    }
  });
```

## CORS Plugin

```typescript
import { Elysia } from 'elysia';
