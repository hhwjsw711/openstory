## Main App Setup

```typescript
import { Elysia } from 'elysia';
import { swagger } from '@elysiajs/swagger';
import { corsPlugin } from './plugins/cors';
import { errorPlugin } from './plugins/error';
import { authPlugin } from './plugins/auth';
import { sequencesRoute } from './routes/sequences';
import { framesRoute } from './routes/frames';
import { stylesRoute } from './routes/styles';
import { jobsRoute } from './routes/jobs';

const app = new Elysia()
  .use(swagger({
    documentation: {
      info: {
        title: 'Velro API',
        version: '1.0.0',
      },
    },
  }))
  .use(corsPlugin)
  .use(errorPlugin)
  .use(authPlugin)
  .get('/', () => ({ message: 'Velro API v1.0.0' }))
  .use(sequencesRoute)
  .use(framesRoute)
  .use(stylesRoute)
  .use(jobsRoute)
  .listen(process.env.PORT ?? 3030);

console.log(
  `🦊 Elysia is running at ${app.server?.hostname}:${app.server?.port}`,
);

export type App = typeof app;
```

## Service Layer Pattern

```typescript
// apps/backend/src/services/sequence-service.ts
import { db } from '../db';
import { sequences } from '../db/schema';
import { eq } from 'drizzle-orm';

export class SequenceService {
  static async create(data: {
    name: string;
    description?: string;
    teamId: string;
    createdBy: string;
  }) {
    const [sequence] = await db.insert(sequences).values(data).returning();
    return sequence;
  }
  
  static async findById(id: string) {
    return db.query.sequences.findFirst({
      where: eq(sequences.id, id),
      with: {
        frames: true,
        style: true,
      },
    });
  }
  
  static async update(id: string, data: Partial<typeof sequences.$inferInsert>) {
    const [updated] = await db
      .update(sequences)
      .set({ ...data, updatedAt: new Date() })
      .where(eq(sequences.id, id))
      .returning();
    return updated;
  }
  
  static async delete(id: string) {
    await db.delete(sequences).where(eq(sequences.id, id));
  }
}

// Usage in route
export const sequencesRoute = new Elysia({ prefix: '/api/sequences' })
  .use(authPlugin)
  .post('/', async ({ body, user, error }) => {
    if (!user) {
      return error(401, 'Authentication required');
    }
    
    const sequence = await SequenceService.create({
      ...body,
      teamId: user.teamId,
      createdBy: user.id,
    });
    
    return { success: true, data: sequence };
  });
```

## Supabase Storage Integration

Velro uses Supabase for PostgreSQL (via Drizzle ORM) and Storage (for generated images/videos), but NOT for Auth (we use BetterAuth).

```typescript
import { createClient } from '@supabase/supabase-js';

// Create Supabase client for Storage only
const supabase = createClient(
  process.env.SUPABASE_URL!,
  process.env.SUPABASE_SERVICE_ROLE_KEY!, // Service role for backend
);

// Upload generated image to Supabase Storage
export async function uploadToSupabaseStorage(params: {
  bucket: string;
  path: string;
  file: Buffer;
  contentType: string;
}): Promise<string> {
  const { data, error } = await supabase.storage
    .from(params.bucket)
    .upload(params.path, params.file, {
      contentType: params.contentType,
      upsert: true,
    });
  
  if (error) {
    throw new Error(`Failed to upload to Supabase Storage: ${error.message}`);
  }
  
  // Get public URL
  const { data: { publicUrl } } = supabase.storage
    .from(params.bucket)
    .getPublicUrl(params.path);
  
  return publicUrl;
}

// Usage in Elysia route
export const uploadRoute = new Elysia({ prefix: '/api/upload' })
  .post('/frame-image', async ({ body, error }) => {
    try {
      const publicUrl = await uploadToSupabaseStorage({
        bucket: 'frames',
        path: `${body.userId}/${body.frameId}.png`,
        file: body.imageBuffer,
        contentType: 'image/png',
      });
      
      return { success: true, url: publicUrl };
    } catch (err) {
      console.error('Upload failed:', err);
      return error(500, 'Failed to upload image');
    }
  });
```

## WebSocket Support

```typescript
import { Elysia } from 'elysia';

export const wsPlugin = new Elysia({ name: 'websocket' })
  .ws('/ws', {
    open(ws) {
      console.log('WebSocket connected:', ws.id);
      ws.subscribe('generation-updates');
    },
    message(ws, message) {
      // Handle incoming messages
      console.log('Received:', message);
    },
    close(ws) {
      console.log('WebSocket disconnected:', ws.id);
      ws.unsubscribe('generation-updates');
    },
  });

// Publish updates from anywhere
import { app } from './index';

app.server?.publish('generation-updates', {
  type: 'frame-generated',
  frameId: 'some-id',
  imageUrl: 'https://...',
});
```
