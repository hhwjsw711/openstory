### Using Custom Hook for User Data
```typescript
'use client';

import { useUser } from "@/hooks/use-user";

export function UserDashboard() {
  const { data: userData, isLoading, error } = useUser();
  
  if (isLoading) return <div>Loading user data...</div>;
  if (error) return <div>Error: {error.message}</div>;
  
  return (
    <div>
      <h1>Welcome, {userData?.user.full_name || "Anonymous User"}!</h1>
      <p>Team: {userData?.teamName || "No team"}</p>
      {userData?.isAnonymous && (
        <div className="bg-yellow-50 p-4 rounded">
          <p>You're using an anonymous account.</p>
          <a href="/login" className="text-blue-600">
            Sign up to save your work permanently
          </a>
        </div>
      )}
    </div>
  );
}
```

