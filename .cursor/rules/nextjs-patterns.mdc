# Next.js 15 App Router Patterns

## Server Components (Default)
```typescript
export default function Page() {
  return <div>Server Component</div>
}

// Async Server Components for data fetching
export default async function Page() {
  const data = await fetchData()
  return <div>{data}</div>
}
```

## Client Components
Use `'use client'` directive only when necessary (for interactivity, hooks, browser APIs):

```typescript
'use client';

import { useState } from 'react'

export function InteractiveComponent() {
  const [count, setCount] = useState(0)
  return <button onClick={() => setCount(c => c + 1)}>{count}</button>
}
```

## Metadata
```typescript
export const metadata = {
  title: 'Page Title',
  description: 'Page description'
}

// Dynamic metadata
export async function generateMetadata({ params }: { params: Promise<{ id: string }> }) {
  const { id } = await params; // Next.js 15: params must be awaited
  return {
    title: `Dynamic Title - ${id}`
  }
}
```

## App Router File Conventions
- `page.tsx` - Page components
- `layout.tsx` - Layout components
- `loading.tsx` - Loading UI
- `error.tsx` - Error UI (must be Client Component)
- `not-found.tsx` - 404 UI
- `route.ts` - API routes

## API Routes Pattern (Velro Standard)

### Standard API Structure with BetterAuth
```typescript
import { NextResponse } from "next/server";
import type { NextRequest } from "next/server";
import { z } from "zod";
import { handleApiError, ValidationError } from "@/lib/errors";
import { authenticateApiRequest } from "@/lib/auth/api-utils";

// 1. Define request schema with Zod
const requestSchema = z.object({
  name: z.string().min(1),
  description: z.string().optional(),
});

// 2. API handler with async params
export async function POST(
  request: NextRequest,
  { params }: { params: Promise<{ id: string }> }
) {
  try {
    // 3. Await params (Next.js 15 requirement)
    const { id } = await params;
    
    // 4. Validate UUID if needed
    const uuidSchema = z.string().uuid();
    uuidSchema.parse(id);
    
    // 5. Check authentication with BetterAuth
    const authResult = await authenticateApiRequest(request);
    if (!authResult.authenticated) {
      return NextResponse.json(
        { error: authResult.error || "Unauthorized" },
        { status: 401 }
      );
    }
    
    const { user, session } = authResult;
    
    // 6. Parse and validate request body
    const body = await request.json();
    const validatedData = requestSchema.parse(body);
    
    // 7. Execute business logic (via server actions)
    const result = await someAction(validatedData);
    
    // 8. Return standardized response
    return NextResponse.json(
      { success: true, data: result },
      { status: 200 }
    );
  } catch (error) {
    // 9. Use centralized error handler
    const velroError = handleApiError(error);
    return NextResponse.json(
      { error: velroError.message },
      { status: velroError.statusCode }
    );
  }
}
```

### GET Endpoint Pattern
```typescript
export async function GET(
  request: NextRequest,
  { params }: { params: Promise<{ id: string }> }
) {
  try {
    const { id } = await params;
    
    // Authenticate with BetterAuth
    const authResult = await authenticateApiRequest(request);
    if (!authResult.authenticated) {
      return NextResponse.json(
        { error: authResult.error || "Unauthorized" },
        { status: 401 }
      );
    }
    
    const data = await fetchData(id);
    return NextResponse.json({ success: true, data });
  } catch (error) {
    const velroError = handleApiError(error);
    return NextResponse.json(
      { error: velroError.message },
      { status: velroError.statusCode }
    );
  }
}
```

### Optional Authentication Pattern
For endpoints that allow both authenticated and anonymous users:

```typescript
export async function GET(request: NextRequest) {
  try {
    // Optional authentication
    const authResult = await authenticateApiRequest(request);
    const userId = authResult.authenticated ? authResult.user.id : null;
    const isAnonymous = authResult.user?.isAnonymous ?? true;
    
    // Adjust behavior based on auth status
    const data = await fetchData(userId, { includePrivate: !isAnonymous });
    
    return NextResponse.json({ success: true, data });
  } catch (error) {
    const velroError = handleApiError(error);
    return NextResponse.json(
      { error: velroError.message },
      { status: velroError.statusCode }
    );
  }
}
```

### Blocking Anonymous Users
For operations that require a full authenticated account:

```typescript
import { requireAuthenticatedUserForMotion } from "@/lib/auth/api-utils";

export async function POST(request: NextRequest) {
  try {
    // Blocks anonymous users
    const authResult = await requireAuthenticatedUserForMotion(request);
    if (!authResult.authenticated) {
      return NextResponse.json(
        { error: authResult.error || "Account required" },
        { status: 403 }
      );
    }
    
    const { user } = authResult;
    
    // Execute authenticated-only operation
    const result = await performOperation(user.id);
    
    return NextResponse.json({ success: true, data: result });
  } catch (error) {
    const velroError = handleApiError(error);
    return NextResponse.json(
      { error: velroError.message },
      { status: velroError.statusCode }
    );
  }
}
```

## Server Actions Pattern

Located in `src/app/actions/*/index.ts`:

```typescript
"use server";

import { z } from "zod";
import { getCurrentUser } from "@/app/actions/user";
import { createServerClient } from "@/lib/supabase/server";

const inputSchema = z.object({
  name: z.string().min(1),
});

export type CreateInput = z.infer<typeof inputSchema>;

export async function createAction(input: CreateInput) {
  try {
    // 1. Authenticate with BetterAuth
    const userResult = await getCurrentUser();
    if (!userResult.success || !userResult.data) {
      return {
        success: false,
        error: "Authentication required",
      };
    }
    
    const { user } = userResult.data;
    
    // 2. Validate input
    const validatedInput = inputSchema.parse(input);
    
    // 3. Get Supabase client for database operations
    const supabase = createServerClient();
    
    // 4. Database operations here
    const { data, error } = await supabase
      .from('table')
      .insert({
        ...validatedInput,
        user_id: user.id,
        created_by: user.id,
      })
      .select()
      .single();
    
    if (error) throw error;
    
    return { success: true, data };
  } catch (error) {
    console.error("[createAction] Error:", error);
    return { 
      success: false, 
      error: error instanceof Error ? error.message : "Unknown error" 
    };
  }
}
```

### Server Action with Anonymous Check
For actions that require authenticated (non-anonymous) users:

```typescript
"use server";

import { MOTION_ACCESS_DENIED_MESSAGE } from "@/constants";
import { getCurrentUser } from "@/app/actions/user";

export async function authenticatedOnlyAction(input: ActionInput) {
  try {
    // Check authentication
    const userResult = await getCurrentUser();
    if (!userResult.success || !userResult.data) {
      return {
        success: false,
        error: "Authentication required",
      };
    }
    
    // Block anonymous users
    if (userResult.data.isAnonymous) {
      return {
        success: false,
        error: MOTION_ACCESS_DENIED_MESSAGE,
      };
    }
    
    const { user } = userResult.data;
    
    // Execute authenticated-only operation
    const result = await performOperation(user.id);
    
    return { success: true, data: result };
  } catch (error) {
    console.error("[authenticatedOnlyAction] Error:", error);
    return {
      success: false,
      error: error instanceof Error ? error.message : "Unknown error",
    };
  }
}
```

### Server Action with System Context
For actions called by webhooks or background jobs:

```typescript
"use server";

import { getCurrentUser } from "@/app/actions/user";
import { createServerClient } from "@/lib/supabase/server";

export async function webhookAction(
  input: ActionInput,
  systemContext: boolean = false
) {
  try {
    const supabase = createServerClient();
    let userId: string;
    
    if (systemContext) {
      // For webhook calls, derive userId from related data
      const { data: relatedRecord } = await supabase
        .from('related_table')
        .select('created_by')
        .eq('id', input.relatedId)
        .single();
      
      if (!relatedRecord?.created_by) {
        return {
          success: false,
          error: "Cannot determine user for system context",
        };
      }
      
      userId = relatedRecord.created_by;
    } else {
      // For user calls, get from session
      const userResult = await getCurrentUser();
      if (!userResult.success || !userResult.data) {
        return {
          success: false,
          error: "Authentication required",
        };
      }
      userId = userResult.data.user.id;
    }
    
    // Execute operation with userId
    const result = await performOperation(userId, input);
    
    return { success: true, data: result };
  } catch (error) {
    console.error("[webhookAction] Error:", error);
    return {
      success: false,
      error: error instanceof Error ? error.message : "Unknown error",
    };
  }
}
```

## Client-Side Authentication (BetterAuth)

### Using BetterAuth Hooks
```typescript
'use client';

import { authClient, useSession } from "@/lib/auth/client";

export function UserProfile() {
  // Get current session with BetterAuth
  const { data: session, isPending, error } = useSession();
  
  if (isPending) return <div>Loading...</div>;
  if (error) return <div>Error: {error.message}</div>;
  
  return (
    <div>
      <p>User ID: {session?.user.id}</p>
      <p>Anonymous: {session?.user.isAnonymous ? "Yes" : "No"}</p>
    </div>
  );
}
```

### Anonymous Session Creation
```typescript
'use client';

import { authClient } from "@/lib/auth/client";
import { useEffect } from "react";

export function AnonymousSessionManager() {
  useEffect(() => {
    async function initAnonymousSession() {
      const { data: session } = await authClient.getSession();
      
      if (!session) {
        // Create anonymous session
        const { data, error } = await authClient.signIn.anonymous();
        
        if (error) {
          console.error("Failed to create anonymous session:", error);
        }
      }
    }
    
    initAnonymousSession();
  }, []);
  
  return null;
}
```

### Sign In/Sign Up with BetterAuth
```typescript
'use client';

import { authClient } from "@/lib/auth/client";
import { useState } from "react";

export function AuthForm() {
  const [email, setEmail] = useState("");
  const [password, setPassword] = useState("");
  const [error, setError] = useState("");
  
  async function handleSignIn() {
    const { data, error } = await authClient.signIn.email({
      email,
      password,
    });
    
    if (error) {
      setError(error.message);
    } else {
      // Redirect or update UI
      window.location.href = "/dashboard";
    }
  }
  
  async function handleSignUp() {
    const { data, error } = await authClient.signUp.email({
      email,
      password,
      name: "User Name", // optional
    });
    
    if (error) {
      setError(error.message);
    } else {
      // Account created and signed in
      window.location.href = "/dashboard";
    }
  }
  
  return (
    <div>
      <input
        type="email"
        value={email}
        onChange={(e) => setEmail(e.target.value)}
        placeholder="Email"
      />
      <input
        type="password"
        value={password}
        onChange={(e) => setPassword(e.target.value)}
        placeholder="Password"
      />
      {error && <p className="text-red-500">{error}</p>}
      <button onClick={handleSignIn}>Sign In</button>
      <button onClick={handleSignUp}>Sign Up</button>
    </div>
  );
}
```

